# {{ ansible_managed }} — VNET jails
# Each jail gets its own network stack via an epair bridged to the matching VLAN,
# with its own default route to the firewall gateway for that VLAN.
# VERIFY per release: ifconfig/route may belong in exec.created vs exec.start.

$j_path = "/jails";

exec.start   = "/bin/sh /etc/rc";
exec.stop    = "/bin/sh /etc/rc.shutdown";
exec.clean;
mount.devfs;
persist;
vnet;

{% for jname, j in freebsd.jails.items() %}
{{ jname }} {                                   # {{ j.role }}, VLAN {{ j.vlan }}
    $epair = "epair{{ j.vlan }}";
    vnet.interface = "${epair}b";
    exec.prestart  = "ifconfig ${epair} create up";
    exec.prestart += "ifconfig ${epair}a up";
    exec.prestart += "ifconfig bridge{{ j.vlan }} addm ${epair}a";
    exec.start    += "ifconfig ${epair}b inet {{ j.ip }} up";
    exec.start    += "route add default {{ j.gw }}";
    exec.poststop  = "ifconfig ${epair}a destroy";
    path = "${j_path}/{{ jname }}";
    host.hostname = "{{ jname }}";
}

{% endfor %}
